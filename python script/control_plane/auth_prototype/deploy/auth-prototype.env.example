# Nom de l'application
AUTH_PROTO_APP_NAME="Control Plane Auth Prototype"

# A remplacer absolument avant exposition a des utilisateurs reels
AUTH_PROTO_SESSION_SECRET=replace-with-a-long-random-secret

# Nom du cookie de session
AUTH_PROTO_SESSION_COOKIE=control_plane_session

# HTTP simple pour la phase de test initiale sur VM
AUTH_PROTO_SECURE_COOKIES=false

# Lax est suffisant pour ce prototype
AUTH_PROTO_SAMESITE=lax

# 8 heures
AUTH_PROTO_SESSION_TTL_SECONDS=28800

# URL publique du control panel derriere Traefik
AUTH_PROTO_PUBLIC_BASE_URL=https://control-panel.cascadya.internal

# URL ouverte par le bouton Wazuh du front.
# Cible attendue: dashboard Wazuh expose en HTTPS interne via WireGuard.
AUTH_PROTO_WAZUH_DASHBOARD_URL=https://wazuh.cascadya.internal
AUTH_PROTO_WAZUH_ALERTS_INDEXER_URL=https://10.42.1.7:9200
AUTH_PROTO_WAZUH_ALERTS_INDEXER_USERNAME=
AUTH_PROTO_WAZUH_ALERTS_INDEXER_PASSWORD=
AUTH_PROTO_WAZUH_ALERTS_INDEX_PATTERN=wazuh-alerts-*
AUTH_PROTO_WAZUH_ALERTS_VERIFY_TLS=false
AUTH_PROTO_WAZUH_ALERTS_CA_CERT_PATH=
AUTH_PROTO_WAZUH_ALERTS_PAGE_SIZE=25
AUTH_PROTO_WAZUH_ALERTS_MIN_RULE_LEVEL=3
AUTH_PROTO_WAZUH_ALERTS_TIMEOUT_SECONDS=10

# Base metier locale par defaut pour le developpement.
# Sur VM, prefere PostgreSQL local a la machine via Docker.
AUTH_PROTO_DATABASE_URL=sqlite+pysqlite:///./auth_prototype/control_panel_auth.db
AUTH_PROTO_DATABASE_ECHO=false

# Etat cible actuel: OIDC actif, login legacy desactive
AUTH_PROTO_OIDC_ENABLED=true
AUTH_PROTO_ENABLE_LEGACY_LOGIN=false

# Issuer Keycloak public
AUTH_PROTO_OIDC_ISSUER_URL=https://auth.cascadya.internal/realms/cascadya-corp

# Recommande sur la VM pour eviter de dependre de Traefik/self-signed en backchannel
AUTH_PROTO_OIDC_DISCOVERY_URL=http://127.0.0.1:8081/realms/cascadya-corp/.well-known/openid-configuration

# Backchannel local depuis la VM du control panel vers Keycloak
AUTH_PROTO_OIDC_INTERNAL_BASE_URL=http://127.0.0.1:8081
AUTH_PROTO_OIDC_VERIFY_TLS=true
AUTH_PROTO_OIDC_CLIENT_ID=control-panel-web
AUTH_PROTO_OIDC_CLIENT_SECRET=change-me-before-use
AUTH_PROTO_OIDC_SCOPES=openid,profile,email
AUTH_PROTO_KEYCLOAK_ADMIN_BASE_URL=http://127.0.0.1:8081
AUTH_PROTO_KEYCLOAK_ADMIN_REALM=master
AUTH_PROTO_KEYCLOAK_ADMIN_USERNAME=admin
AUTH_PROTO_KEYCLOAK_ADMIN_PASSWORD=change-me-before-use
AUTH_PROTO_KEYCLOAK_MANAGED_REALM=cascadya-corp

# Bootstrap facultatif pour donner le role admin a certains emails au premier login
AUTH_PROTO_BOOTSTRAP_ADMIN_EMAILS=

# Roles attribues automatiquement a un nouvel utilisateur miroir
AUTH_PROTO_JIT_DEFAULT_ROLES=

# Provisioning Ansible reel
AUTH_PROTO_PROVISIONING_PLAYBOOK_ROOT=/opt/control-panel/control_plane/auth_prototype/provisioning_ansible
AUTH_PROTO_PROVISIONING_DEFAULT_PLAYBOOK=full-ipc-wireguard-onboarding
AUTH_PROTO_PROVISIONING_EXECUTION_MODE=mock
AUTH_PROTO_PROVISIONING_SSH_KEY_PATH=
AUTH_PROTO_PROVISIONING_SSH_KEY_PASSPHRASE=
AUTH_PROTO_PROVISIONING_SSH_PASSWORD=
AUTH_PROTO_PROVISIONING_BECOME_PASSWORD=
AUTH_PROTO_PROVISIONING_STEP_TIMEOUT_SECONDS=900
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_URL_DEFAULT=https://10.30.0.1:8443
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_INVENTORY_HOSTNAME=broker-DEV1-S
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_ANSIBLE_HOST=51.15.64.139
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_ANSIBLE_USER=ubuntu
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_ANSIBLE_PORT=22
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_SSH_KEY_PATH=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_SSH_KEY_PASSPHRASE=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_SSH_PASSWORD=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_BECOME_PASSWORD=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_WIREGUARD_INTERFACE=wg0
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_WIREGUARD_ADDRESS=10.30.0.1/24
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_WIREGUARD_LISTEN_PORT=51820
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_PROBE_PORT=9443
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_PROBE_URL_DEFAULT=https://51.15.64.139:9443
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_PROBE_TOKEN=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_PROBE_CA_CERT_PATH=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_VAULT_ADDR=http://51.15.36.65:8200
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_VAULT_TOKEN=
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_VAULT_KV_MOUNT=secret
AUTH_PROTO_PROVISIONING_REMOTE_UNLOCK_BROKER_VAULT_KV_PREFIX=remote-unlock
AUTH_PROTO_PROVISIONING_WIREGUARD_ENDPOINT_DEFAULT=51.15.64.139:51820
AUTH_PROTO_PROVISIONING_WIREGUARD_PEER_PUBLIC_KEY_DEFAULT=
AUTH_PROTO_PROVISIONING_AUTO_GENERATE_WIREGUARD_PRIVATE_KEY=true
AUTH_PROTO_PROVISIONING_WAZUH_MANAGER_ADDRESS_DEFAULT=10.42.1.7
AUTH_PROTO_PROVISIONING_WAZUH_MANAGER_PORT_DEFAULT=1514
AUTH_PROTO_PROVISIONING_WAZUH_REGISTRATION_SERVER_DEFAULT=10.42.1.7
AUTH_PROTO_PROVISIONING_WAZUH_REGISTRATION_PORT_DEFAULT=1515
AUTH_PROTO_PROVISIONING_WAZUH_AGENT_GROUP_DEFAULT=
AUTH_PROTO_PROVISIONING_WAZUH_REGISTRATION_PASSWORD=
AUTH_PROTO_PROVISIONING_WAZUH_REGISTRATION_CA_CERT_PATH=
AUTH_PROTO_PROVISIONING_IPC_ALLOY_MIMIR_REMOTE_WRITE_URL_DEFAULT=http://10.42.1.4:9009/api/v1/push
AUTH_PROTO_PROVISIONING_IPC_ALLOY_SCRAPE_INTERVAL_DEFAULT=15s
AUTH_PROTO_PROVISIONING_IPC_ALLOY_SCRAPE_TIMEOUT_DEFAULT=10s
AUTH_PROTO_PROVISIONING_IPC_ALLOY_TENANT_DEFAULT=
AUTH_PROTO_PROVISIONING_IPC_ALLOY_RETENTION_PROFILE_DEFAULT=classic
AUTH_PROTO_PROVISIONING_IPC_ALLOY_MIMIR_USERNAME=
AUTH_PROTO_PROVISIONING_IPC_ALLOY_MIMIR_PASSWORD=
AUTH_PROTO_PROVISIONING_IPC_ALLOY_MIMIR_VERIFY_TLS=false
AUTH_PROTO_PROVISIONING_IPC_ALLOY_MIMIR_CA_CERT_PATH=

# Mode de decouverte reseau pour les IPC: mock, tcp, auto, ssh
AUTH_PROTO_DISCOVERY_MODE=auto

# Identifiants et timeouts utilises par la sonde SSH du control panel
AUTH_PROTO_DISCOVERY_SSH_USERNAME=cascadya
AUTH_PROTO_DISCOVERY_SSH_PORT=22
AUTH_PROTO_DISCOVERY_SSH_KEY_PATH=
AUTH_PROTO_DISCOVERY_DOWNSTREAM_PROBE_IP=
AUTH_PROTO_DISCOVERY_CONNECT_TIMEOUT_SECONDS=5
AUTH_PROTO_DISCOVERY_COMMAND_TIMEOUT_SECONDS=15
