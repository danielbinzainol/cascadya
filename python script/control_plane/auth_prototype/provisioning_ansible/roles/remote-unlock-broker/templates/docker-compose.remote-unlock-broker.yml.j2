services:
  remote-unlock-broker:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: "{{ remote_unlock_broker_container_name }}"
    restart: unless-stopped
    env_file:
      - broker.env
    command:
      - --listen-host
      - "{{ remote_unlock_broker_listen_host }}"
      - --listen-port
      - "{{ remote_unlock_broker_bind_port }}"
      - --server-cert
      - "/certs/server.crt"
      - --server-key
      - "/certs/server.key"
      - --client-ca
      - "/certs/ca.crt"
      - --vault-addr
      - "{{ remote_unlock_broker_vault_addr }}"
      - --vault-kv-mount
      - "{{ remote_unlock_broker_vault_kv_mount }}"
      - --vault-kv-prefix
      - "{{ remote_unlock_broker_vault_kv_prefix }}"
      - --challenge-ttl-seconds
      - "{{ remote_unlock_broker_challenge_ttl_seconds }}"
{% if remote_unlock_broker_control_plane_probe_enable | bool %}
      - --control-plane-listen-host
      - "{{ remote_unlock_broker_control_plane_probe_listen_host }}"
      - --control-plane-listen-port
      - "{{ remote_unlock_broker_control_plane_probe_bind_port }}"
      - --control-plane-probe-client-cert
      - "/certs/probe-client.crt"
      - --control-plane-probe-client-key
      - "/certs/probe-client.key"
      - --control-plane-probe-ca-cert
      - "/certs/probe-ca.crt"
      - --control-plane-probe-nats-url
      - "{{ remote_unlock_broker_control_plane_probe_nats_url }}"
      - --control-plane-probe-monitoring-url
      - "{{ remote_unlock_broker_control_plane_probe_monitoring_url }}"
      - --control-plane-order-subject
      - "{{ remote_unlock_broker_control_plane_order_subject }}"
      - --control-plane-order-max-items
      - "{{ remote_unlock_broker_control_plane_order_max_items }}"
      - --control-plane-probe-timeout-seconds
      - "{{ remote_unlock_broker_control_plane_probe_timeout_seconds }}"
{% endif %}
    ports:
{% if remote_unlock_broker_publish_address | length > 0 %}
      - "{{ remote_unlock_broker_publish_address }}:{{ remote_unlock_broker_bind_port }}:{{ remote_unlock_broker_bind_port }}"
{% else %}
      - "{{ remote_unlock_broker_bind_port }}:{{ remote_unlock_broker_bind_port }}"
{% endif %}
{% if remote_unlock_broker_control_plane_probe_enable | bool %}
{% if remote_unlock_broker_control_plane_probe_publish_address | length > 0 %}
      - "{{ remote_unlock_broker_control_plane_probe_publish_address }}:{{ remote_unlock_broker_control_plane_probe_bind_port }}:{{ remote_unlock_broker_control_plane_probe_bind_port }}"
{% else %}
      - "{{ remote_unlock_broker_control_plane_probe_bind_port }}:{{ remote_unlock_broker_control_plane_probe_bind_port }}"
{% endif %}
{% endif %}
{% if remote_unlock_broker_control_plane_probe_enable | bool %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    volumes:
      - ./certs:/certs:ro
