server {
    listen 443 ssl http2;
    server_name {{ vault_vm_keycloak_domain }};

    ssl_certificate {{ vault_vm_keycloak_tls_cert_path }};
    ssl_certificate_key {{ vault_vm_keycloak_tls_key_path }};

    location / {
{% for cidr in vault_vm_keycloak_allowed_cidrs %}
        allow {{ cidr }};
{% endfor %}
        deny all;

        proxy_pass http://{{ vault_vm_keycloak_http_bind }}:{{ vault_vm_keycloak_http_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port {{ vault_vm_keycloak_host_header_port }};
    }
}

server {
    listen 80;
    server_name {{ vault_vm_keycloak_domain }};
    return 301 https://$host$request_uri;
}
