# Mender config for the V2 build chain.
# This file is sourced by scripts/build_mender_image.sh.

# Build outputs
DEPLOY_IMAGE_NAME="cascadya-mender-base"
MENDER_ARTIFACT_NAME="cascadya-edge-os-v1.0.0"

# Optional: point WSL/Linux builds at a base image produced elsewhere
# (for example under /mnt/c/.../output-debian-base/debian-base.img).
# Leave empty to use the repo-local Linux path.
BASE_IMAGE_PATH=""

# Device identity
MENDER_DEVICE_TYPE="cascadya-ipc"

# Standalone is the default mode for the current industrial workflow.
# Hosted / production fields remain empty until the project moves to a pull model.
# Modes:
#   standalone -> bake client + boot integration only
#   hosted     -> hosted.mender.io with tenant token
#   production -> on-prem or self-hosted server URL
MENDER_SERVER_MODE="standalone"
MENDER_HOSTED_REGION="eu"
MENDER_SERVER_URL=""
MENDER_SERVER_CERT=""
MENDER_TENANT_TOKEN=""

# Partitioning for the converted base image.
# The final target /data partition will still be enlarged by Zero-Touch.
MENDER_STORAGE_TOTAL_SIZE_MB="24576"
MENDER_BOOT_PART_SIZE_MB="300"
MENDER_DATA_PART_SIZE_MB="4096"

# Rootfs size is expressed in KiB by mender-convert.
# 10 GiB = 10485760 KiB, to keep parity with the validated target layout.
IMAGE_ROOTFS_SIZE="10485760"
IMAGE_ROOTFS_EXTRA_SPACE="0"

# Optional add-ons. Keep these off until the OTA path is validated.
MENDER_ADDON_CONNECT_INSTALL="n"
MENDER_ADDON_CONFIGURE_INSTALL="n"
MENDER_SETUP_INSTALL="auto"
MENDER_SNAPSHOT_INSTALL="auto"
