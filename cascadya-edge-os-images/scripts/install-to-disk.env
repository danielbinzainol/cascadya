# Zero-Touch phase 2 toggle.
# false: keep /data as a plain ext4 partition on the target (default, stable mode)
# true: create or preserve a LUKS container on partition 4 during cloning
ZERO_TOUCH_ENABLE_LUKS=true

# Temporary passphrase used only when ZERO_TOUCH_ENABLE_LUKS=true
DATA_LUKS_PASSPHRASE=admin

# Runtime name written into /etc/crypttab when LUKS mode is enabled
TARGET_CRYPTTAB_NAME=cascadya_data

# Embedded target OS payload copied by packer/debian-v2-prod.pkr.hcl
PAYLOAD_IMAGE_PATH=/opt/cascadya/payload/cascadya-mender-base.img.xz
PAYLOAD_IMAGE_COMPRESSION=xz
MENDER_DEVICE_TYPE=cascadya-ipc
